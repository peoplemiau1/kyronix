<?xml version="1.0"?>
<JWM>
  <Desktops width="4" height="1" />

  <TitleButtonOrder>t i m x</TitleButtonOrder>

  <Tray x="0" y="0" height="20" autohide="off" valign="top" border="0">
    <TaskList maxwidth="120"/>
    <Dimmer/>
    <Clock format="%H:%M"/>
  </Tray>

  <RootMenu onroot="3">
    <Program label="xterm">xterm</Program>
    <Program label="xclock">xclock</Program>
    <Program label="xcalc">xcalc</Program>
    <Program label="xeyes">xeyes</Program>
    <Program label="xedit">xedit</Program>
    <Separator/>
    <Restart label="restart"/>
    <Exit label="exit" confirm="false"/>
  </RootMenu>

  <WindowStyle>
    <Font>-misc-fixed-bold-r-semicondensed--13-120-75-75-c-60-iso8859-1</Font>
    <Width>1</Width>
    <Height>20</Height>
    <Corner>0</Corner>
    <Active>
      <Background>#4d8888</Background>
      <Foreground>#ffffff</Foreground>
      <Outline>#4d8888</Outline>
    </Active>
    <Inactive>
      <Background>#4d8888</Background>
      <Foreground>#ffffff</Foreground>
      <Outline>#4d8888</Outline>
    </Inactive>
  </WindowStyle>

  <TaskListStyle>
    <font>-misc-fixed-bold-r-semicondensed--13-120-75-75-c-60-iso8859-1</font>
    <Active>
      <Background>#4d8888</Background>
      <Foreground>#ffffff</Foreground>
    </Active>
    <Inactive>
      <Background>#1a3a3a</Background>
      <Foreground>#a0c4c4</Foreground>
    </Inactive>
  </TaskListStyle>

  <TrayStyle>
    <font>-misc-fixed-bold-r-semicondensed--13-120-75-75-c-60-iso8859-1</font>
    <Background>#1a3a3a</Background>
    <Foreground>#a0c4c4</Foreground>
  </TrayStyle>

  <PagerStyle>
    <Active>
      <Background>#4d8888</Background>
    </Active>
    <Inactive>
      <Background>#1a3a3a</Background>
    </Inactive>
  </PagerStyle>

  <ClockStyle>
    <font>-misc-fixed-bold-r-semicondensed--13-120-75-75-c-60-iso8859-1</font>
    <Background>#1a3a3a</Background>
    <Foreground>#7aacac</Foreground>
  </ClockStyle>

  <MenuStyle>
    <font>-misc-fixed-bold-r-semicondensed--13-120-75-75-c-60-iso8859-1</font>
    <Active>
      <Background>#4d8888</Background>
      <Foreground>#ffffff</Foreground>
    </Active>
    <Inactive>
      <Background>#1a3a3a</Background>
      <Foreground>#cccccc</Foreground>
    </Inactive>
  </MenuStyle>

  <PopupStyle>
    <Background>#1a3a3a</Background>
    <Foreground>#cccccc</Foreground>
  </PopupStyle>

  <FocusModel>sloppy</FocusModel>
  <SnapMode>border</SnapMode>
  <SnapDistance>5</SnapDistance>
  <MoveMode>opaque</MoveMode>
  <ResizeMode>opaque</ResizeMode>

  <DoubleClickSpeed>400</DoubleClickSpeed>
  <DoubleClickDelta>4</DoubleClickDelta>

  <Mouse mask="A" button="1">move</Mouse>
  <Mouse mask="A" button="3">resize</Mouse>

  <Key mask="A" key="Tab">next</Key>
  <Key mask="AS" key="Tab">prev</Key>
  <Key mask="A" key="F2">exec:xterm</Key>
  <Key mask="A" key="F4">close</Key>
  <Key mask="A" key="F9">minimize</Key>
  <Key mask="A" key="F10">maximize</Key>
  <Key mask="A" key="d">desktop</Key>

  <Include>/etc/jwmrc.local</Include>
</JWM>
